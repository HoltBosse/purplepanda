---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Form from '../../../form/Form.astro';
import { getAllFields } from '../../../form/index.js';
import { getDb } from '../../../db/db.js';
import { users } from '../../../db/schema.js';
import { eq } from 'drizzle-orm';
import { capitalize } from '../../../string';
import { getSettingsForm } from './form.js';
import { createFormFlashSession } from '../../../form/session.js';

const db = getDb();
const fields = getAllFields();
const form = getSettingsForm();
---

<AdminLayout>
	<Form form={form} fields={fields}>
		<div slot="before-fields" class="flex items-center justify-between align-middle border-b border-base-300 pt-2">
			<h1 class="text-2xl font-semibold">Settings</h1>
			<button class="btn btn-primary">Save</button>
		</div>
	</Form>
</AdminLayout>
