---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getDb } from '../../../db/db.js';
import { forms } from '../../../db/schema.js';
import { CircleCheck } from '@lucide/astro';

const db = getDb();
const allForms = await db.select().from(forms);
---

<AdminLayout>
    <div class="flex items-center justify-between align-middle border-b border-base-300 pt-2 pb-4">
        <h1 class="text-2xl font-semibold">Forms</h1>
        <a href="/admin/forms/new" class="btn btn-primary">New</a>
    </div>
    <table class="table p-2 bg-base-100 rounded-lg">
        <thead>
            <tr>
                <th class="w-px whitespace-nowrap">State</th>
                <th>Form</th>
            </tr>
        </thead>
        <tbody>
            {allForms.map(form => (
                <tr>
                    <th>
                        <button class="btn btn-square">
                            <CircleCheck size={20} class={form.state === 1 ? "text-green-500" : "text-red-500"} />
                        </button>
                    </th>
                    <td>
                        <a href={`/admin/forms/edit/${form.id}`}>
                            <div class="font-bold link link-info link-hover">{(form.content as any)?.root?.props?.name || 'Untitled'}</div>
                        </a>
                    </td>
                </tr>
            ))}
        </tbody>
    </table>
</AdminLayout>
