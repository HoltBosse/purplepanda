---
import '../../styles/global.css';

const error = Astro.url.searchParams.get("error");
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body class="min-h-screen flex items-center justify-center bg-base-200">
    <div class="card bg-base-100 shadow-md w-full max-w-sm">
      <div class="card-body">
        <h1 class="card-title text-2xl mb-2">Admin Login</h1>
        {error === "invalid" && (
          <p class="text-error text-sm mb-2">Invalid password. Please try again.</p>
        )}
        <form method="POST" action="/admin/login-action" class="flex flex-col gap-4">
          <label class="form-control w-full">
            <div class="label">
              <span class="label-text font-medium">Username</span>
            </div>
            <input
              type="text"
              name="username"
              required
              class="input input-bordered w-full"
            />
          </label>
          <label class="form-control w-full">
            <div class="label">
              <span class="label-text font-medium">Password</span>
            </div>
            <input
              type="password"
              name="password"
              required
              autofocus
              class="input input-bordered w-full"
            />
          </label>
          <button type="submit" class="btn btn-primary w-full">Login</button>
        </form>
      </div>
    </div>
  </body>
</html>
