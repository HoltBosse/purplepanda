---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getDb } from '../../../db/db.js';
import { pages } from '../../../db/schema.js';
import { CircleCheck } from '@lucide/astro';

const db = getDb();
const allPages = await db.select().from(pages);
---

<AdminLayout>
	<div class="flex items-center justify-between align-middle border-b border-base-300 pt-2 pb-4">
        <h1 class="text-2xl font-semibold">Pages</h1>
        <a href="/admin/pages/new" class="btn btn-primary">New</a>
    </div>
    <table class="table p-2 bg-base-100 rounded-lg">
        <thead>
            <tr>
                <th class="w-px whitespace-nowrap">State</th>
                <th>Page</th>
            </tr>
        </thead>
        <tbody>
            {allPages.map(page => (
                <tr>
                    <th>
                        <button class="btn btn-square">
                            <CircleCheck size={20} class={page.state === 1 ? "text-green-500" : "text-red-500"} />
                        </button>
                    </th>
                    <td>
                        <a href={`/admin/pages/edit/${page.id}`}>
                            <div class="font-bold link link-info link-hover">{(page.content as any)?.root?.props?.title || 'Untitled'}</div>
                        </a>
                    </td>
                </tr>
            ))}
        </tbody>
    </table>
</AdminLayout>
