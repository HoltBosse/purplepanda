---
import AdminBareLayout from '../../../layouts/AdminBareLayout.astro';
import PagePuckEditor from '../../../components/PagePuckEditor';
import { getDb } from '../../../db/db.js';
import { settings, templates } from '../../../db/schema.js';
import { eq, sql } from 'drizzle-orm';
import type { Data } from '@puckeditor/core';

const db = getDb();
const [defaultTemplate] = await db
    .select()
    .from(settings)
    .leftJoin(templates, sql`(${templates.id})::text = (${settings.value} #>> '{}')`)
    .where(eq(settings.key, 'default_template'))
    .limit(1);

const editorProps = defaultTemplate?.templates?.content
    ? { templateData: defaultTemplate.templates.content as Data }
    : {};

---
<AdminBareLayout>
    <PagePuckEditor client:only="react" {...editorProps} />
</AdminBareLayout>