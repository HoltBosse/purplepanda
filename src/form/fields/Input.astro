---
import type { ComponentProps } from "astro/types";
import BaseField from "../BaseField.astro";

interface Props extends ComponentProps<typeof BaseField> {
  placeholder?: string;
  classList?: string;
}

const { placeholder, classList, ...baseProps } = Astro.props;
const { id, name, value, required } = baseProps;
---

<BaseField {...baseProps}>
  <input
    class={classList}
    type="text"
    name={name}
    id={id}
    placeholder={placeholder}
    value={value}
    required={required}
  />
</BaseField>